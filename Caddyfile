{
	# Global options
	frankenphp {
		# Enable the worker mode for performance
		num_threads 4
	}
	# Disable admin API for security and cleaner logs
	admin off
	# Disable HTTPS auto redirection since Railway handles SSL
	auto_https off
	# Storage configuration to avoid non-root permission issues
	storage file_system {
		root /tmp/caddy_storage
	}
}

:{$PORT:8080} {
	# Set the document root for Bedrock
	root * web/

	# We wrap everything in a route block to ensure proper execution order
	route {
		# Handle static assets in Sage theme with aggressive caching
		handle_path /app/themes/sage/public/build/* {
			root * web/app/themes/sage/public/build/
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		# Enable the FrankenPHP worker mode for the main index.php
		# Using 2 workers to balance performance and RAM usage for low traffic
		php_server {
			worker index.php 2
		}

		# Ensure HTML and other dynamic content is not cached by the browser
		# but is still generated fast by the worker mode.
		header ?Cache-Control "no-cache, no-store, must-revalidate"
	}

	# Global compression
	encode zstd gzip

	# Logging
	log {
		output stdout
		format json
	}
}
