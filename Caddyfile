{
    frankenphp
    order php_server before file_server
    auto_https off
    admin off
}

:{$PORT:80} {
    root * /app/web
    encode zstd gzip
    
    # WordPress Permalinks
    try_files {path} {path}/ /index.php?{query}

    # PHP Server
    php_server

    log {
        output stdout
        format json
    }
}
